# ─── Base de datos ───────────────────────────────────────
POSTGRES_PASSWORD=supersecret123
DATABASE_URL=postgresql://thesis:supersecret123@localhost:5432/thesis_review

# ─── Redis ───────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── MinIO / S3 ──────────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=thesis-documents
MINIO_ENDPOINT=localhost
MINIO_PORT=9000

# ─── Azure OpenAI ────────────────────────────────────────
AZURE_OPENAI_API_KEY=tu-azure-api-key
AZURE_OPENAI_ENDPOINT=https://tu-recurso.openai.azure.com/
AZURE_OPENAI_API_INSTANCE_NAME=tu-recurso
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_CHAT_MINI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=text-embedding-3-large

# ─── Autenticación ───────────────────────────────────────
JWT_SECRET=tu-jwt-secret-de-256-bits
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
NEXTAUTH_SECRET=tu-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# ─── Email ───────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=tu-app-password

# ─── ORCID (OAuth) ───────────────────────────────────────
ORCID_CLIENT_ID=APP-...
ORCID_CLIENT_SECRET=...
ORCID_REDIRECT_URI=http://localhost:3001/api/v1/orcid/callback

# ─── Copyleaks (Plagio) ──────────────────────────────────
COPYLEAKS_EMAIL=...
COPYLEAKS_API_KEY=...
COPYLEAKS_WEBHOOK_SECRET=...

# ─── Configuración académica ─────────────────────────────
MAX_GRADE=20                  # Escala: 20 (Perú), 5 (EE.UU.), 100
LOW_COMPLIANCE_ALERT=65       # % mínimo para alertar al asesor
FT_MIN_PAIRS=500              # Pares mínimos para lanzar fine-tuning

# ─── Frontend ────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
