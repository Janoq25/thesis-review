{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["jest", "node"],
    "baseUrl": "../../"
  },
  "include": ["./**/*.ts", "../**/*.ts"],
  "exclude": ["../../node_modules", "../../dist"]
}
